---
interface Props {
  icon?: string;
  title: string;
  description: string;
  url: string;
  urlDescription: string; 
  isBlue?: boolean;     
  buttonCard?: boolean;
}

const {
  icon,
  title,
  description,
  url,
  urlDescription,
  isBlue = false,
  buttonCard = false,
} = Astro.props;
 
const containerClasses = isBlue
  ? 'bg-blue-950 border-blue-100'
  : 'bg-green-500 border-green-100';

const buttonClasses = isBlue
  ? 'bg-green-600 text-white'
  : 'text-white underline';

const buttonWrapperClasses = buttonCard
  ? 'flex w-full justify-start'
  : 'flex w-full justify-end';
---

<article
  class:list={[
    'rounded-lg',
    'gap-4',
    'px-6',
    'py-8',
    'border',
    'flex',
    'flex-1',
    'flex-col',
    'shadow-card',
    'h-full',
    containerClasses,
  ]}
>
  <div class="card__header">
    {
      icon && (
        <div class="mb-0 h-14 w-14 text-green-300">
          <img
            src={icon}
            alt=""
            width="56"
            height="56"
            loading="lazy"
            class="h-full w-full object-contain"
          />
        </div>
      )
    }
  </div>

  <div class="flex h-full w-full grow flex-col items-start justify-between gap-4">
    <div class="w-full">
      <h3 class="text-lg font-semibold text-white mb-2">
        {title}
      </h3>
      <p class="text-white text-sm leading-relaxed">
        {description}
      </p>
    </div>

    <div class={buttonWrapperClasses}>
      {
        buttonCard ? (
          <button
            type="button"
            class:list={[
              'px-6',
              'py-3',
              'rounded-lg',
              'font-bold',
              'block',
              'overflow-hidden',
              'text-ellipsis',
              '!text-left',
              'whitespace-nowrap',
              buttonClasses,
            ]}
            onclick={`location.href = '${url}'`}
          >
            {urlDescription}
          </button>
        ) : (
          <button
            type="button"
            class:list={[
              'underline',
              'font-bold',
              'block',
              'overflow-hidden',
              'text-ellipsis',
              '!text-left',
              'whitespace-nowrap',
              buttonClasses,
            ]}
            onclick={`location.href = '${url}'`}
          >
            {urlDescription}
          </button>
        )
      }
    </div>
  </div>
</article>

<style>
  .shadow-card {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }
</style>