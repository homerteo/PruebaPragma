{
  "name": "strapi",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/strapi/src",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "strapi develop",
        "cwd": "apps/strapi"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "strapi build",
        "cwd": "apps/strapi"
      }
    }
  }
}