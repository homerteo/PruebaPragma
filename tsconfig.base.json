{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@bhd-test/shared-domain": ["libs/shared-domain/src/index.ts"],
      "@bhd-test/ui-react": ["libs/ui-react/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "tmp"]
}
